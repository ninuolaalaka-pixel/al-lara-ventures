import { checkCORS } from "./_security.js";
import crypto from "crypto";

export const config = {
  api: { bodyParser: true },
};

export default async function handler(req, res) {
  if (!checkCORS(req, res)) return;
  if (req.method !== "POST") return res.status(405).json({ error: "Method not allowed" });

  const notificationToken = process.env.TAMARA_SB_NOTIF_TOKEN;
  const signature = req.headers["x-tamara-signature"];

  // 1. SIGNATURE VERIFICATION
  const bodyString = JSON.stringify(req.body); 
  const expectedSignature = crypto
    .createHmac("sha256", notificationToken || "")
    .update(bodyString)
    .digest("hex");

  if (signature !== expectedSignature) {
    console.error("Signature Mismatch! Unauthorized webhook attempt.");
    // return res.status(403).json({ success: false }); // Uncomment for production security
  }

  const { order_id, event_type } = req.body;

  try {
    // 2. AUTO-CAPTURE ON APPROVAL
    if (event_type === "order_approved") {
      console.log(`ORDER APPROVED: ${order_id}. Triggering internal capture...`);
      
      // We call our internal capture handler to finalize the money
      await fetch(`https://${req.headers.host}/api/tamara-capture`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ 
          orderId: order_id,
          amount: req.body.total_amount?.amount // Ensure we pass the actual amount
        })
      });
    }

    return res.status(200).send("OK");
  } catch (error) {
    console.error("Webhook Logic Error:", error);
    return res.status(500).json({ success: false });
  }
}